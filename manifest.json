{
  "key": "",
  "manifest_version": 3,
  "name": "AI Voice Assistant",
  "version": "1.0.0",
  "description": "AI语音助理 - 语音对话、飞书操作、幻灯片生成、网页问答",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [
    "https://open.bigmodel.cn/",
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "AI Voice Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.min.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
